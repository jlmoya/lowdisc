    lds=lowdisc_configure(lds,"-scrambling","Owen-Faure-Tezuka");

    [lds,computed] = lowdisc_next (lds,50);
    lds=lowdisc_destroy(lds);
    assert_checkalmostequal(expected,computed,[],1.e-5);
end
