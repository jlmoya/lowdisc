//
// Check the bithi1 function
//
computed = [];
ilist =  [
    22      
    96      
    83     
    56      
    41     
     6     
    26      
    11     
     4     
    64     
];
expected =  [
  5
  7
  7
  6
  6
  3
  5
  4
  3
  7
];
for i = 1:size(ilist,"*")
  j = ilist(i);
  computed ( $ + 1 ) = lowdisc_bithi1 (j );
end
assert_checkequal ( computed , expected );
