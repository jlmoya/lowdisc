  <refnamediv>
    <refname>lowdisc_combinesum</refname>
    <refpurpose>Search 2D combinations with given sum.</refpurpose>
  </refnamediv>


<refsynopsisdiv>
   <title>Calling Sequence</title>
   <synopsis>
   C = lowdisc_combinesum(m)
   
   </synopsis>
</refsynopsisdiv>

<refsection>
   <title>Parameters</title>
   <variablelist>
   <varlistentry><term>m :</term>
      <listitem><para> a 1-by-1 matrix of doubles, the sum</para></listitem></varlistentry>
   <varlistentry><term>C :</term>
      <listitem><para> a n-by-2 matrix of doubles, where n is the number of combinations</para></listitem></varlistentry>
   </variablelist>
</refsection>

<refsection>
   <title>Description</title>
   <para>
Search all combinations of (d(1),d(2))
which sum to m, with d(1),d(2) in {0,1,2,..,m}.
   </para>
   <para>
</para>
</refsection>

<refsection>
   <title>Examples</title>
   <programlisting role="example"><![CDATA[
// Search combinations (d(1),d(2)) which sum to 3.
C = lowdisc_combinesum(3)

   ]]></programlisting>
</refsection>

